{
  "name": "biblehub-auto-linker",
  "version": "0.1.1",
  "description": "Obsidian plugin that automatically converts Bible references into BibleHub Markdown links.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "test": "vitest run"
  },
  "keywords": [
    "obsidian",
    "bible",
    "biblehub"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.23.0",
    "obsidian": "^1.5.12",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vitest": "^2.0.5"
  }
}
